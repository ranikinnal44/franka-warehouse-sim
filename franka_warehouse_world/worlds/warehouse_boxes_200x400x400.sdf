    <!-- ================= BOX ================= -->
    <model name="box">
      <pose>0.4500 -0.3000 0.9500 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>3.2000</mass>
          <inertia>
            <ixx>0.085333</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.053333</iyy><iyz>0</iyz>
            <izz>0.053333</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <box><size>0.2000 0.4000 0.4000</size></box>
