          </material>
        </visual>
      </link>
      <link name="leg_1">
        <collision name="c">
          <geometry><box><size>0.0600 0.0600 0.7000</size></box></geometry>
          <pose>-0.2700 0.5700 0.3500 0 0 0</pose>
        </collision>
        <visual name="v">
          <geometry><box><size>0.0600 0.0600 0.7000</size></box></geometry>
          <pose>-0.2700 0.5700 0.3500 0 0 0</pose>
          <material>
            <ambient>0.55 0.38 0.22 1</ambient>
            <diffuse>0.55 0.38 0.22 1</diffuse>
          </material>
        </visual>
      </link>
      <link name="leg_2">
        <collision name="c">
          <geometry><box><size>0.0600 0.0600 0.7000</size></box></geometry>
          <pose>0.8700 -0.5700 0.3500 0 0 0</pose>
        </collision>
        <visual name="v">
          <geometry><box><size>0.0600 0.0600 0.7000</size></box></geometry>
