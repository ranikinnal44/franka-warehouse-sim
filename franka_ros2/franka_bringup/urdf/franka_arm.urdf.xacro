<?xml version="1.0" encoding="utf-8"?>
<!--
  Bringup entry point for single-arm robots (FR3/FP3/FER variants).

  Composes the franka_description base robot with ros2_control hardware interface.
  Used by franka_bringup launch files and MoveIt config.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="$(arg robot_type)">

  <!-- robot_type must be declared before include (used in filename resolution) -->
  <xacro:arg name="robot_type" default="fr3"/>

  <!-- Base robot (geometry, links, joints — declares all description args) -->
  <xacro:include filename="$(find franka_description)/robots/$(arg robot_type)/$(arg robot_type).urdf.xacro"/>
  <!-- ros2_control hardware interface macro -->
  <xacro:include filename="$(find franka_hardware)/ros2_control/franka_arm.ros2_control.xacro"/>

  <!-- ros2_control-specific arguments (not declared by description) -->
  <xacro:arg name="robot_ip" default=""/>
  <xacro:arg name="use_fake_hardware" default="false"/>
  <xacro:arg name="fake_sensor_commands" default="false"/>
  <xacro:arg name="gazebo_effort" default="false"/>
  <xacro:arg name="is_async" default="false"/>
  <xacro:arg name="thread_priority" default="50"/>

  <!-- ros2_control hardware interface -->
  <xacro:franka_arm_ros2_control
      robot_type="$(arg robot_type)"
      robot_ip="$(arg robot_ip)"
      use_fake_hardware="$(arg use_fake_hardware)"
      fake_sensor_commands="$(arg fake_sensor_commands)"
      gazebo="$(arg gazebo)"
      hand="$(arg hand)"
      gazebo_effort="$(arg gazebo_effort)"
      arm_prefix="${modified_prefix}"
      is_async="$(arg is_async)"
      thread_priority="$(arg thread_priority)"/>

</robot>
