<?xml version="1.0" encoding="utf-8"?>
<!--
  Gazebo entry point for single-arm (FR3/FP3/FER).

  Includes the franka_description base robot, ros2_control hardware interface,
  and Gazebo-specific sensors.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="$(arg robot_type)">

    <!-- ================================================================ -->
    <!-- Macro includes                                                    -->
    <!-- ================================================================ -->
    <xacro:arg name="robot_type" default="fr3"/>

    <!-- Base robot (Layer 1) -->
    <xacro:include filename="$(find franka_description)/robots/$(arg robot_type)/$(arg robot_type).urdf.xacro"/>
    <!-- ros2_control hardware interface -->
    <xacro:include filename="$(find franka_hardware)/ros2_control/franka_arm.ros2_control.xacro"/>
    <!-- Gazebo extras -->
    <xacro:include filename="$(find franka_gazebo_bringup)/urdf/sensors.xacro"/>

    <!-- ================================================================ -->
    <!-- Arguments                                                        -->
    <!-- ================================================================ -->
    <xacro:arg name="arm_prefix" default=""/>
    <xacro:arg name="hand" default="true"/>
    <xacro:arg name="ee_id" default="franka_hand"/>
    <xacro:arg name="gazebo_effort" default="false"/>

    <!-- Compute prefix (same logic as fr3.urdf.xacro) -->
    <xacro:property name="prefix" value="$(arg arm_prefix)"/>
    <xacro:property name="modified_prefix" value="${prefix + '_' if prefix else ''}"/>

    <!-- ================================================================ -->
    <!-- ros2_control hardware interface (gazebo mode)                    -->
    <!-- ================================================================ -->
    <xacro:franka_arm_ros2_control
        robot_type="$(arg robot_type)"
        gazebo="true"
        hand="$(arg hand)"
        gazebo_effort="$(arg gazebo_effort)"
        arm_prefix="${modified_prefix}"/>

    <!-- ================================================================ -->
    <!-- Gazebo sensors                                                    -->
    <!-- ================================================================ -->

    <!-- Arm IMUs -->
    <xacro:franka_gazebo_arm_imus arm_prefix="$(arg arm_prefix)" robot_type="$(arg robot_type)" imu_side="top"/>
    <xacro:franka_gazebo_arm_imus arm_prefix="$(arg arm_prefix)" robot_type="$(arg robot_type)" imu_side="bottom"/>

</robot>
